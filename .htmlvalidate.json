{
  "extends": ["html-validate:recommended"],
  "rules": {
    "no-conditional-comment": "off",
    "no-inline-style": "off",
    "no-trailing-whitespace": "off",
    "void-style": "off",
    "attribute-boolean-style": "off",
    "no-implicit-button-type": "off",
    "hidden-focusable": "off",
    "wcag/h30": "off",
    "wcag/h32": "off",
    "wcag/h71": "off",
    "doctype-style": "off",
    "attr-quotes": "off",
    "empty-heading": "off",
    "element-permitted-content": "off"
  }
}
